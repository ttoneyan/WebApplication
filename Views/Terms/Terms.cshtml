@{
    ViewData["Title"] = "Terms";
}

@section Styles {
    <link rel="stylesheet" href="~/css/terms.css" asp-append-version="true" />
}

<div class="terms-container">
@*     FIRST SECTION: Primary Market (Photo on Left, Conditions on Right) *@
    <section class="market-section">
        <h2 class="section-title">Առաջնային շուկա նոր</h2>

        <div class="card-wrapper">
            <div class="image-container">
                <img src="https://mycar2026.blob.core.windows.net/container-videosimages/termsphoto1.jpg" alt="Primary Market Dealership">
            </div>

            <div class="info-box">
                <p class="info-header">
                    Ծանոթացիր առաջնային շուկայից նոր մեքենայի ձեռքբերման օնլայն վարկի պայմաններին
                </p>

                <div class="features-grid">

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">14.4 %</div>
                            <div class="label">Անվանական տոկոսադրույք</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">15.38 - 15.41 %</div>
                            <div class="label">Փաստացի տոկոսադրույք</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">3 - 50 մլն ՀՀ դրամ</div>
                            <div class="label">Վարկի սահմանաչափ</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">5 %</div>
                            <div class="label">Նվազագույն կանխավճար</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">84 ամիս</div>
                            <div class="label">Ժամկետ</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">18 - 58 տարեկան</div>
                            <div class="label">Ով կարող է դիմել</div>
                        </div>
                    </div>

                </div>
                <button class="btn-action">Տես մեքենաները</button>
            </div>
        </div>
    </section>


@*SECOND SECTION: Secondary Market (Photo on Right, Conditions on Left)*@
    <section class="market-section">
        <h2 class="section-title">Երկրորդային շուկա նոր</h2>
        <div class="card-wrapper row-reverse">
            <div class="image-container">
                <img src="https://mycar2026.blob.core.windows.net/container-videosimages/termsphoto2.jpg" alt="Secondary Market Dealership">
            </div>

            <div class="info-box">
                <p class="info-header">
                    Ծանոթացիր երկրորդային շուկայից նոր մեքենայի ձեռքբերման օնլայն վարկի պայմաններին
                </p>

                <div class="features-grid">
                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">14.4 %</div>
                            <div class="label">Անվանական տոկոսադրույք</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">15.38 - 15.41 %</div>
                            <div class="label">Փաստացի տոկոսադրույք</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">3 - 50 մլն ՀՀ դրամ</div>
                            <div class="label">Վարկի սահմանաչափ</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">10 %</div>
                            <div class="label">Նվազագույն կանխավճար</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">84 ամիս</div>
                            <div class="label">Ժամկետ</div>
                        </div>
                    </div>

                    <div class="feature-item">
                        <div class="green-dot"></div>
                        <div>
                            <div class="value">18 - 58 տարեկան</div>
                            <div class="label">Ով կարող է դիմել</div>
                        </div>
                    </div>
                </div>
                <button class="btn-action">Տես մեքենաները</button>
            </div>
        </div>
    </section>
</div>