@{
    ViewData["Title"] = "Login";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
}
<div class="login-page-container">

    <!-- Floating White Login Card -->
    <div class="login-card">
        <h1 class="login-title">Մուտք</h1>
        <p class="login-subtitle">Մուտքագրիր տվյալներդ՝ հարթակ մուտք գործելու համար</p>

        <form method="post" class="login-form">
            <!-- Email Input Group -->
            <div class="input-group">
                <label for="Email">Էլ. հասցե</label>
                <input type="email" id="Email" name="Email" required />
            </div>

            <!-- Password Input Group -->
            <div class="input-group password-group">
                <label for="Password">Գաղտնաբառ</label>
                <div class="password-wrapper">
                    <input type="password" id="Password" name="Password" required />
                    <!-- Eye icon for show/hide password toggle -->
                    <span class="toggle-password">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </span>
                </div>
            </div>

            <!-- Forgot Password Link -->
            <div class="forgot-password-container">
                <a href="#" class="forgot-password-link">Մոռացե՞լ ես գաղտնաբառը</a>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn-login">Մուտք</button>
        </form>

        <!-- Registration Redirect Footer -->
        <div class="login-footer">
            Դեռ գրանցված չե՞ս. <a href="#" class="register-link">գրանցվիր</a>
        </div>
    </div>

</div>